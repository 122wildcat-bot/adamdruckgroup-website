# Copy to .env for local dev. On Railway, set these as service variables.

# Secret used to sign login sessions (JWT). MUST be set to a long random
# string in production. Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# The email that is automatically granted the admin role on signup.
ADMIN_EMAIL=yourrealtoradamd@gmail.com

# Port (Railway sets this automatically; default 3000 locally)
PORT=3000
